{
  "name": "@silsigan/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^10.0.0",
    "expo-doctor": "^1.18.22",
    "get-tsconfig": "^4.14.0",
    "typescript": "~5.9.2"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  }
}
